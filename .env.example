# ============================================================
# VoIP Announcement Calling Service — Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- SIP Provider: Linphone Free SIP Service ---
# Create 2 free accounts on sip.linphone.org via the Linphone app:
#   1. API account → used by this service to place calls
#   2. Phone account → configured on your iPhone/Android to receive calls
#
# Push notifications work automatically — phone rings even when app is closed.
SIP_DOMAIN=sip.linphone.org
SIP_TRANSPORT=tls
SIP_PROXY=sip:sip.linphone.org:5061;transport=tls
# SIP_NAT_ADDRESS=<your-public-ip>
SIP_USERNAME=wcs-announcer
SIP_PASSWORD=<your-linphone-password>

# --- RTP Audio Ports ---
RTP_PORT_MIN=10000
RTP_PORT_MAX=10020

# --- NAT / Audio ---
# Public IP address for RTP if behind NAT (Linphone handles this automatically by default)
# SIP_NAT_ADDRESS=
# Directory where generated audio files are stored
# AUDIO_DIR=/audio

# --- API Server ---
API_PORT=8000

# --- HTTPS / Let's Encrypt ---
# To enable HTTPS, set your domain and ensure certs exist on the host at
# /etc/letsencrypt/live/<SSL_DOMAIN>/ (fullchain.pem + privkey.pem).
# The container mounts /etc/letsencrypt as read-only and auto-detects certs.
# Leave SSL_DOMAIN empty for HTTP-only mode (local development).
# SSL_ENABLED=true          # force HTTPS (auto-detected if empty)
# SSL_DOMAIN=api.example.com

# --- TTS Engine ---
# Options: gtts (Google TTS, needs internet, best quality)
#          zalo (Zalo AI, 6 Vietnamese voices, needs internet)
#          espeak (offline, robotic, always works)
#          responsivevoice (ResponsiveVoice API, Vietnamese voices, needs internet)
TTS_ENGINE=gtts

# --- Zalo TTS (only used when TTS_ENGINE=zalo) ---
# Voice speaker_id (1-6):
#   1: Nữ miền Nam    3: Nam miền Nam    5: Nữ miền Bắc
#   2: Nữ miền Bắc    4: Nam miền Bắc    6: Nữ miền Nam
ZALO_SPEAKER_ID=1
# Speed factor (0.8 - 1.2)
ZALO_SPEED=1.0

# --- ResponsiveVoice TTS (only used when TTS_ENGINE=responsivevoice) ---
# API secret (required): create in dashboard → "Server-to-server API secrets"
# https://responsivevoice.org
RV_API_KEY=
# Site ID for X-API-Key header (required, copy from dashboard)
RV_SITE_ID=
# Voice gender (optional): male or female. Default: API default voice.
# RV_GENDER=
# Speech rate 0.0-2.0 (default: 1.0)
# RV_RATE=1.0
# Voice pitch 0.0-2.0 (default: 1.0)
# RV_PITCH=1.0

# --- Call Settings ---
# Maximum call duration in seconds (covers ringing + playback)
CALL_TIMEOUT=30

# --- TTS Cache ---
# Cache synthesized audio to avoid re-calling TTS API for the same text + config.
# Set to "false" to disable caching.
TTS_CACHE_ENABLED=true
# Directory for cached WAV files (default: system temp dir / wcs_tts_cache).
# TTS_CACHE_DIR=/audio/.tts_cache
# Maximum age in days for cached TTS files. Files older than this
# will be deleted when DELETE /api/v1/tts/cache is called.
# TTS_CACHE_MAX_AGE_DAYS=30

# --- Logging ---
LOG_LEVEL=INFO

# --- API Security ---
# Master key used to sign access tokens. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<generate-random-64-char-hex>
